{
  "manifest_version": 3,
  "name": "公众号文章数据助手",
  "version": "1.1.2",
  "description": "纯插件版公众号和视频号运营简表导出工具，不包含本地服务和地域战报。",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://api.weixin.qq.com/*",
    "https://channels.weixin.qq.com/*"
  ],
  "action": {
    "default_title": "公众号文章数据助手",
    "default_popup": "popup.html"
  },
  "options_page": "settings.html"
}
