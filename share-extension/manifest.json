{
  "manifest_version": 3,
  "name": "公众号文章数据助手 - 分享版",
  "version": "1.0.0",
  "description": "纯插件版公众号文章运营简表导出工具，不包含地域战报和本地 Python 服务。",
  "permissions": [
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://api.weixin.qq.com/*"
  ],
  "action": {
    "default_title": "公众号文章数据助手",
    "default_popup": "popup.html"
  },
  "options_page": "settings.html"
}
